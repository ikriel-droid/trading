{
  "market": "KRW-BTC",
  "initial_cash": 1000000.0,
  "fee_rate": 0.0005,
  "slippage_rate": 0.0007,
  "strategy": {
    "fast_ema": 8,
    "slow_ema": 21,
    "rsi_period": 14,
    "macd_fast": 8,
    "macd_slow": 21,
    "macd_signal": 5,
    "adx_period": 14,
    "min_adx": 18.0,
    "bollinger_period": 20,
    "bollinger_stddev": 2.0,
