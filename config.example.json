    "breakout_lookback": 20,
    "volume_sma_period": 20,
    "volume_spike_multiplier": 1.3,
    "buy_threshold": 65.0,
    "sell_threshold": 40.0
  },
  "risk": {
    "risk_per_trade_fraction": 0.01,
    "max_position_fraction": 0.35,
    "stop_atr_multiple": 2.2,
    "take_profit_atr_multiple": 3.5,
    "trailing_atr_multiple": 1.8,
    "atr_period": 14,
    "minimum_stop_fraction": 0.015,
    "max_portfolio_drawdown_fraction": 0.2
  },
  "runtime": {
    "cooldown_bars_after_exit": 1,
    "max_trades_per_day": 5,
    "daily_loss_limit_fraction": 0.03,
    "session_start": "",
    "session_end": "",
    "allowed_weekdays": [0, 1, 2, 3, 4, 5, 6],
    "journal_path": "data/trade-journal.jsonl",
    "poll_seconds": 10.0,
    "max_history": 300,
